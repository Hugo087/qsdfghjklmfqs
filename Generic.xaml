<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:GuidControl">

    <Style TargetType="{x:Type local:GuidTextBox}">
        <Setter Property="Background"        Value="#1E1E2E"/>
        <Setter Property="Foreground"        Value="#E0E0F0"/>
        <Setter Property="BorderBrush"       Value="#3D3D5C"/>
        <Setter Property="BorderThickness"   Value="1.5"/>
        <Setter Property="FontFamily"        Value="Cascadia Code, Consolas, Courier New"/>
        <Setter Property="FontSize"          Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:GuidTextBox}">

                    <!-- Couleurs internes au template -->
                    <ControlTemplate.Resources>
                        <Color x:Key="ColorSurface">#2A2A3E</Color>
                        <Color x:Key="ColorMuted">#8888AA</Color>

                        <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}"/>
                        <SolidColorBrush x:Key="BrushMuted"   Color="{StaticResource ColorMuted}"/>

                        <!-- Couleurs des 5 segments -->
                        <Color x:Key="Seg1Color">#7C6FCD</Color>
                        <Color x:Key="Seg2Color">#3DBAED</Color>
                        <Color x:Key="Seg3Color">#FF9F43</Color>
                        <Color x:Key="Seg4Color">#FF5370</Color>
                        <Color x:Key="Seg5Color">#3DDC84</Color>

                        <SolidColorBrush x:Key="Seg1Brush" Color="{StaticResource Seg1Color}"/>
                        <SolidColorBrush x:Key="Seg2Brush" Color="{StaticResource Seg2Color}"/>
                        <SolidColorBrush x:Key="Seg3Brush" Color="{StaticResource Seg3Color}"/>
                        <SolidColorBrush x:Key="Seg4Brush" Color="{StaticResource Seg4Color}"/>
                        <SolidColorBrush x:Key="Seg5Brush" Color="{StaticResource Seg5Color}"/>

                        <Style x:Key="SegCountStyle" TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New"/>
                            <Setter Property="FontSize"   Value="11"/>
                            <Setter Property="Opacity"    Value="0.55"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Margin"     Value="0,3,0,0"/>
                        </Style>
                    </ControlTemplate.Resources>

                    <!-- Racine -->
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="2">
                        <StackPanel>

                            <!-- ── Label ─────────────────────────────── -->
                            <TextBlock x:Name="PART_Label"
                                       Text="{TemplateBinding Label}"
                                       Foreground="{StaticResource BrushMuted}"
                                       FontFamily="Segoe UI, Arial"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="14,10,0,6"/>

                            <!-- ── Zone de saisie ─────────────────────── -->
                            <Border Background="{StaticResource BrushSurface}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Margin="6,0,6,0">
                                <Grid>
                                    <!-- Placeholder -->
                                    <TextBlock x:Name="PART_Placeholder"
                                               Text="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                               Foreground="{StaticResource BrushMuted}"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               Opacity="0.4"
                                               IsHitTestVisible="False"/>
                                    <!-- TextBox de saisie -->
                                    <TextBox x:Name="PART_TextBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}"
                                             CaretBrush="#7C6FCD"
                                             FontFamily="{TemplateBinding FontFamily}"
                                             FontSize="{TemplateBinding FontSize}"
                                             Padding="12,10"
                                             VerticalContentAlignment="Center"
                                             MaxLength="36"
                                             CharacterCasing="Upper"/>
                                </Grid>
                            </Border>

                            <!-- ── Barres de progression (8-4-4-4-12) ── -->
                            <Grid Margin="8,8,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Seg 1 : 8 -->
                                <StackPanel Grid.Column="0">
                                    <Border x:Name="PART_Seg1Bar" Height="3" CornerRadius="2" Margin="0,0,2,0"
                                            Background="#327C6FCD"/>
                                    <TextBlock x:Name="PART_Seg1Count" Text="0/8"
                                               Style="{StaticResource SegCountStyle}"
                                               Foreground="{StaticResource Seg1Brush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="—"
                                           Foreground="{TemplateBinding BorderBrush}"
                                           VerticalAlignment="Center" Margin="4,0" FontSize="10"/>

                                <!-- Seg 2 : 4 -->
                                <StackPanel Grid.Column="2">
                                    <Border x:Name="PART_Seg2Bar" Height="3" CornerRadius="2" Margin="1,0"
                                            Background="#323DBAED"/>
                                    <TextBlock x:Name="PART_Seg2Count" Text="0/4"
                                               Style="{StaticResource SegCountStyle}"
                                               Foreground="{StaticResource Seg2Brush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="—"
                                           Foreground="{TemplateBinding BorderBrush}"
                                           VerticalAlignment="Center" Margin="4,0" FontSize="10"/>

                                <!-- Seg 3 : 4 -->
                                <StackPanel Grid.Column="4">
                                    <Border x:Name="PART_Seg3Bar" Height="3" CornerRadius="2" Margin="1,0"
                                            Background="#32FF9F43"/>
                                    <TextBlock x:Name="PART_Seg3Count" Text="0/4"
                                               Style="{StaticResource SegCountStyle}"
                                               Foreground="{StaticResource Seg3Brush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="5" Text="—"
                                           Foreground="{TemplateBinding BorderBrush}"
                                           VerticalAlignment="Center" Margin="4,0" FontSize="10"/>

                                <!-- Seg 4 : 4 -->
                                <StackPanel Grid.Column="6">
                                    <Border x:Name="PART_Seg4Bar" Height="3" CornerRadius="2" Margin="1,0"
                                            Background="#32FF5370"/>
                                    <TextBlock x:Name="PART_Seg4Count" Text="0/4"
                                               Style="{StaticResource SegCountStyle}"
                                               Foreground="{StaticResource Seg4Brush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="7" Text="—"
                                           Foreground="{TemplateBinding BorderBrush}"
                                           VerticalAlignment="Center" Margin="4,0" FontSize="10"/>

                                <!-- Seg 5 : 12 -->
                                <StackPanel Grid.Column="8">
                                    <Border x:Name="PART_Seg5Bar" Height="3" CornerRadius="2" Margin="2,0,0,0"
                                            Background="#323DDC84"/>
                                    <TextBlock x:Name="PART_Seg5Count" Text="0/12"
                                               Style="{StaticResource SegCountStyle}"
                                               Foreground="{StaticResource Seg5Brush}"/>
                                </StackPanel>
                            </Grid>

                            <!-- ── Statut ──────────────────────────────── -->
                            <TextBlock x:Name="PART_Status"
                                       Text="Entrez un GUID"
                                       Foreground="{StaticResource BrushMuted}"
                                       FontFamily="Segoe UI, Arial"
                                       FontSize="11"
                                       Margin="8,0,8,10"/>

                        </StackPanel>
                    </Border>

                    <!-- Triggers visuels sur IsEnabled -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
